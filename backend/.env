NODE_ENV=development
PORT=5000

# Mongo
# MONGODB_URI=mongodb+srv://abdulhameethum_db_user:abdul1234@cluster0.aqgkeye.mongodb.net/?appName=Cluster0
# If Atlas is not reachable, fallback to local MongoDB
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/amazon_likee

# Auth
JWT_ACCESS_SECRET=change_me_super_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated). Leave empty to allow all in dev.
CORS_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_MAX=300

# Uploads
MAX_FILE_SIZE_BYTES=5242880

# Cloudinary (preferred). If not set, local storage fallback used.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Shiprocket
SHIPROCKET_API_KEY=your_shiprocket_api_key
SHIPROCKET_SECRET=your_shiprocket_secret

# Optional: if you explicitly want admin self-registration (not recommended)
ALLOW_ADMIN_REGISTRATION=false

# Admin bootstrap (use with: npm run seed:admin)
ADMIN_NAME=Platform Admin
ADMIN_PHONE=9999999999
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
